// Vibe Workspace — slice 0a schema.
// Only the four entities required to prove the project/folder/task spine.
// Remaining 13 entities from CLAUDE.md will be added in later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite for local dev only — explicit deviation from the pack default
  // (Postgres). Approved by user during slice-0 planning.
  // URL hardcoded because the harness blocks writes to .env in this sandbox.
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  projects    Project[]
  connections ModelProviderConnection[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  folders        Folder[]
  repositoryLink RepositoryLink?
  deployTarget   DeployTarget?
  rules          ProjectRule[]
  contexts       ProjectContext[]
  skillRefs      ProjectSkillReference[]

  @@index([ownerId])
}

// Free-text rules the user attaches to a project. Intended to be
// surfaced in future AI-assist flows as constraints ("do not use
// library X", "always add tests"). Slice 4a persists them; downstream
// slices will inject them into provider calls.
model ProjectRule {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title String
  body  String
  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, order])
}

// Free-text context snippets attached to a project. Same future
// contract as ProjectRule but distinct semantics (description /
// background, not constraints).
model ProjectContext {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  label   String
  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, updatedAt])
}

// Named references to skills the project relies on. `source` is an
// optional freeform pointer (URL, path, package name) — slice 4a just
// stores the metadata, no runtime lookup yet.
model ProjectSkillReference {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name   String
  source String?

  createdAt DateTime @default(now())

  @@index([projectId])
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@index([projectId])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  // SQLite does not support Prisma enums; `status` is a string constrained
  // to TaskStatus values (see src/lib/domain/task-status.ts).
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  folderId String
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  messages           TaskMessage[]
  attachments        TaskAttachment[]
  selectionSnapshots ModelSelectionSnapshot[]
  runs               TaskRun[]

  @@index([folderId])
}

// Append-only execution history for a task. Lifecycle canonicalized in
// src/lib/domain/task-run-status.ts:
//   REQUESTED -> RUNNING -> DONE | FAILED
// Slice 4b uses a synchronous stub runner (no real provider calls) that
// snapshots the current provider/model and message count at trigger time
// so future runs can be diffed against prior runs.
model TaskRun {
  id     String @id @default(cuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  status String @default("REQUESTED")

  // Snapshot of the provider/model selection at the moment the run was
  // requested. Nullable so the run row exists even when no model was
  // selected (the runner surfaces that as TASK_NO_MODEL_SELECTED).
  provider String?
  model    String?

  // Snapshot of the message count at trigger time. Useful for diffing
  // future runs against a prior baseline.
  messageCount Int @default(0)

  requestedAt DateTime  @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?

  errorCode   String?
  errorDetail String?

  @@index([taskId, requestedAt])
}

model TaskAttachment {
  id         String   @id @default(cuid())
  filename   String
  mimeType   String
  sizeBytes  Int
  // Opaque key returned by the storage adapter (never the original
  // filename — that lives in `filename` for display only).
  storageKey String
  createdAt  DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// A user-registered model provider connection. Slice 1c stores only the
// provider id (must be in the canonical catalog) and a human-readable
// label. Real credentials, secret encryption, and connection health checks
// land in a future secrets/auth slice.
model ModelProviderConnection {
  id        String   @id @default(cuid())
  provider  String
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  selections ModelSelectionSnapshot[]

  @@index([ownerId])
}

// One-per-project link to an external repository (MVP: GitHub only). The
// model distinguishes *requested* state (what the user asked for) from
// *observed* state (what the provider confirmed), because the pack forbids
// faking progress. Status transitions: REQUESTED -> OBSERVED or FAILED.
// Canonical status values live in src/lib/domain/repository-link-status.ts.
model RepositoryLink {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  provider String @default("github")

  // Requested state — filled when the user kicks off the bootstrap flow.
  requestedOwner   String
  requestedName    String
  requestedPrivate Boolean @default(true)
  requestedAt      DateTime @default(now())

  // Observed state — filled after the provider confirms the repo exists.
  observedOwner String?
  observedName  String?
  observedUrl   String?
  observedAt    DateTime?

  status      String  @default("REQUESTED")
  errorCode   String?
  errorDetail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One-per-project deploy target (MVP: Railway only). The user pastes
// the Railway project/service/environment identifiers from the Railway
// dashboard; auto-creation of services is a later slice.
model DeployTarget {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  provider String @default("railway")

  railwayProjectId     String
  railwayServiceId     String
  railwayEnvironmentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs            DeployRun[]
  previewEndpoint PreviewEndpoint?
}

// Append-only deploy run. Status lifecycle canonicalized in
// src/lib/domain/deploy-run-status.ts:
//   REQUESTED -> BUILDING -> DEPLOYING -> LIVE | FAILED
// Slice 3 drives it synchronously: the adapter decides the terminal
// state in a single round-trip. Background reconcile is a later slice.
model DeployRun {
  id       String @id @default(cuid())
  targetId String
  target   DeployTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  status String @default("REQUESTED")

  commitSha String?
  branch    String?

  // External identifier returned by the provider (Railway deployment id).
  externalId String?

  requestedAt DateTime  @default(now())
  observedAt  DateTime?
  finishedAt  DateTime?

  errorCode   String?
  errorDetail String?

  events DeployEvent[]

  @@index([targetId, requestedAt])
}

// Append-only log of status transitions + messages for a deploy run.
// Kinds canonicalized in src/lib/domain/deploy-event-kind.ts.
model DeployEvent {
  id    String    @id @default(cuid())
  runId String
  run   DeployRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  kind    String
  message String
  // Optional JSON payload (stored as text in SQLite).
  payload String?

  createdAt DateTime @default(now())

  @@index([runId, createdAt])
}

// Current preview URL for a target. Updated only when a run reaches LIVE
// with a non-null URL; failed runs leave the prior preview untouched so
// the UI can honestly label it "stale".
model PreviewEndpoint {
  id       String @id @default(cuid())
  targetId String @unique
  target   DeployTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  url        String
  observedAt DateTime @default(now())
  lastRunId  String?
}

// Append-only history of (provider, model) chosen for a given task. The
// "current" selection of a task is the most recent snapshot.
model ModelSelectionSnapshot {
  id        String   @id @default(cuid())
  provider  String
  model     String
  takenAt   DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Optional pointer to the connection backing this selection. Nullable
  // because slice 1c lets users pick a (provider, model) without yet
  // having a connection registered.
  connectionId String?
  connection   ModelProviderConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([taskId, takenAt])
}

model TaskMessage {
  id        String   @id @default(cuid())
  // SQLite does not support Prisma enums; `role` is a string constrained to
  // MessageRole values (see src/lib/domain/message-role.ts).
  role      String   @default("USER")
  // Content kind constrained to MessageKind values (see
  // src/lib/domain/message-kind.ts). Slice 5a adds structured kinds on top
  // of plain TEXT: PLAN, TOOL_CALL, TOOL_RESULT. Existing rows default to
  // TEXT and render identically.
  kind      String   @default("TEXT")
  content   String
  // Optional JSON-serialized payload. Shape depends on `kind` (see
  // src/lib/domain/message-kind.ts for the documented shapes).
  payload   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Optional self-relation so a TOOL_RESULT row can be nested under its
  // originating TOOL_CALL. Slice 5a supports one level of nesting; deeper
  // hierarchies are out of scope.
  parentMessageId String?
  parent          TaskMessage?  @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: Cascade)
  children        TaskMessage[] @relation("MessageThread")

  @@index([taskId])
  @@index([taskId, createdAt])
  @@index([parentMessageId])
}
