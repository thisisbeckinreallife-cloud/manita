// Vibe Workspace — slice 0a schema.
// Only the four entities required to prove the project/folder/task spine.
// Remaining 13 entities from CLAUDE.md will be added in later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite for local dev only — explicit deviation from the pack default
  // (Postgres). Approved by user during slice-0 planning.
  // URL hardcoded because the harness blocks writes to .env in this sandbox.
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  projects    Project[]
  connections ModelProviderConnection[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  folders        Folder[]
  repositoryLink RepositoryLink?

  @@index([ownerId])
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]

  @@index([projectId])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  // SQLite does not support Prisma enums; `status` is a string constrained
  // to TaskStatus values (see src/lib/domain/task-status.ts).
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  folderId String
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  messages           TaskMessage[]
  attachments        TaskAttachment[]
  selectionSnapshots ModelSelectionSnapshot[]

  @@index([folderId])
}

model TaskAttachment {
  id         String   @id @default(cuid())
  filename   String
  mimeType   String
  sizeBytes  Int
  // Opaque key returned by the storage adapter (never the original
  // filename — that lives in `filename` for display only).
  storageKey String
  createdAt  DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// A user-registered model provider connection. Slice 1c stores only the
// provider id (must be in the canonical catalog) and a human-readable
// label. Real credentials, secret encryption, and connection health checks
// land in a future secrets/auth slice.
model ModelProviderConnection {
  id        String   @id @default(cuid())
  provider  String
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  selections ModelSelectionSnapshot[]

  @@index([ownerId])
}

// One-per-project link to an external repository (MVP: GitHub only). The
// model distinguishes *requested* state (what the user asked for) from
// *observed* state (what the provider confirmed), because the pack forbids
// faking progress. Status transitions: REQUESTED -> OBSERVED or FAILED.
// Canonical status values live in src/lib/domain/repository-link-status.ts.
model RepositoryLink {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  provider String @default("github")

  // Requested state — filled when the user kicks off the bootstrap flow.
  requestedOwner   String
  requestedName    String
  requestedPrivate Boolean @default(true)
  requestedAt      DateTime @default(now())

  // Observed state — filled after the provider confirms the repo exists.
  observedOwner String?
  observedName  String?
  observedUrl   String?
  observedAt    DateTime?

  status      String  @default("REQUESTED")
  errorCode   String?
  errorDetail String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Append-only history of (provider, model) chosen for a given task. The
// "current" selection of a task is the most recent snapshot.
model ModelSelectionSnapshot {
  id        String   @id @default(cuid())
  provider  String
  model     String
  takenAt   DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Optional pointer to the connection backing this selection. Nullable
  // because slice 1c lets users pick a (provider, model) without yet
  // having a connection registered.
  connectionId String?
  connection   ModelProviderConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([taskId, takenAt])
}

model TaskMessage {
  id        String   @id @default(cuid())
  // SQLite does not support Prisma enums; `role` is a string constrained to
  // MessageRole values (see src/lib/domain/message-role.ts). Slice 1a only
  // creates USER messages; ASSISTANT/SYSTEM land with provider integration.
  role      String   @default("USER")
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([taskId, createdAt])
}
